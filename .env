# Browser Automation Framework Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=browser-automation-framework
APP_VERSION=1.0.0
APP_DESCRIPTION="A robust browser automation framework with LLM integration"
APP_ENVIRONMENT=development
APP_DEBUG=true

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=your-secret-key-here-generate-a-secure-one
API_KEY_HEADER=X-API-Key
ALLOWED_HOSTS=["*"]

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/browser_automation
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=browser_automation
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
LLM_PROVIDER=gemini
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=models/gemini-2.5-flash-preview-04-17
GEMINI_REQUESTS_PER_SECOND=1.0
GEMINI_MAX_BUCKET_SIZE=10

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_REQUESTS_PER_MINUTE=60

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# =============================================================================
# BROWSER CONFIGURATION
# =============================================================================
BROWSER_TYPE=chrome
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30
BROWSER_PAGE_LOAD_TIMEOUT=30
BROWSER_IMPLICIT_WAIT=10
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080
BROWSER_POOL_SIZE=5
BROWSER_DOWNLOAD_DIR=./downloads

# Chrome-specific options (comma-separated)
CHROME_OPTIONS=--no-sandbox,--disable-dev-shm-usage,--disable-gpu,--disable-extensions

# =============================================================================
# TASK EXECUTION CONFIGURATION
# =============================================================================
DEFAULT_TASK_TIMEOUT=300
DEFAULT_RETRY_COUNT=3
DEFAULT_RETRY_DELAY=1.0
MAX_PARALLEL_TASKS=5
WORKFLOW_TIMEOUT=1800
WORKFLOW_CHECKPOINT_INTERVAL=60

# Target application settings
TARGET_BASE_URL=https://dev.gotrust.tech
LOGIN_EMAIL=your-test-email@example.com
LOGIN_PASSWORD=your-test-password

# Cookie consent settings
COOKIE_CONSENT_TIMEOUT=5
COOKIE_CONSENT_BUTTONS=["Allow all","Accept all","Accept"]

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/application.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5
LOG_CORRELATION_ID_HEADER=X-Correlation-ID

# Structured logging options
LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_LEVEL=true
LOG_INCLUDE_LOGGER_NAME=true
LOG_INCLUDE_CORRELATION_ID=true

# =============================================================================
# METRICS CONFIGURATION
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_NAMESPACE=browser_automation

# Prometheus settings
PROMETHEUS_ENABLED=true
PROMETHEUS_MULTIPROC=false

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_ENABLED=true
CACHE_TYPE=memory
CACHE_TTL=3600

# Redis settings (if using Redis cache)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# SECRETS MANAGEMENT
# =============================================================================
SECRETS_BACKEND=environment
SECRETS_MASTER_KEY=your-master-key-for-file-based-secrets

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# These settings are only used in development environment

# Enable debug features
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_MOCK_SERVICES=false

# Development database (optional override)
DEV_DATABASE_URL=postgresql://postgres:password@localhost:5432/browser_automation_dev

# Development LLM settings (for testing with lower limits)
DEV_GEMINI_REQUESTS_PER_SECOND=2.0
DEV_MAX_PARALLEL_TASKS=3

# =============================================================================
# TESTING SETTINGS
# =============================================================================
# These settings are used during testing

TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/browser_automation_test
TEST_BROWSER_HEADLESS=true
TEST_LLM_PROVIDER=mock
TEST_DISABLE_EXTERNAL_CALLS=true

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# These settings should be overridden in production

# Production database
PROD_DATABASE_URL=postgresql://user:pass@prod-db:5432/browser_automation_prod

# Production LLM settings
PROD_GEMINI_REQUESTS_PER_SECOND=1.0
PROD_MAX_PARALLEL_TASKS=10

# Production browser settings
PROD_BROWSER_HEADLESS=true
PROD_BROWSER_POOL_SIZE=10

# Production logging
PROD_LOG_LEVEL=INFO
PROD_LOG_FORMAT=json

# =============================================================================
# MONITORING & ALERTING
# =============================================================================
# External monitoring service configurations

# Sentry (error tracking)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development

# DataDog (metrics and logging)
DATADOG_API_KEY=your-datadog-api-key-here
DATADOG_APP_KEY=your-datadog-app-key-here

# Slack (notifications)
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_CHANNEL=#browser-automation-alerts

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable specific features

ENABLE_PARALLEL_EXECUTION=true
ENABLE_STATE_PERSISTENCE=true
ENABLE_METRICS_COLLECTION=true
ENABLE_HEALTH_CHECKS=true
ENABLE_CACHING=true
ENABLE_RETRY_LOGIC=true

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Performance-related settings

# Connection pool settings
HTTP_POOL_CONNECTIONS=10
HTTP_POOL_MAXSIZE=10
HTTP_MAX_RETRIES=3

# Async settings
ASYNC_WORKER_COUNT=4
ASYNC_QUEUE_SIZE=100

# Memory settings
MAX_MEMORY_USAGE_MB=1024
GARBAGE_COLLECTION_THRESHOLD=0.8
